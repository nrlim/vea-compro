// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  company   String
  email     String
  message   String
  product   String?
  attachment String?
  createdAt DateTime @default(now())

  @@map("contact_requests")
}

// ── Admin Panel Models ─────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String
  price       String?  // Made optional for flexibility
  imageUrl     String?  @map("image_url")
  images       String[] @default([])
  manualUrl    String?  @map("manual_url")    // For Manual Book
  datasheetUrl String?  @map("datasheet_url") // For Datasheet
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // Hashed password
  fullName  String?  @map("full_name")
  role      String   @default("staff") // "admin" | "staff"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model AppSettings {
  id                 String   @id @default("global")
  whatsappNumber     String?  @default("628123456789") @map("whatsapp_number")
  whatsappMessage    String?  @default("Halo PT VEA, saya ingin berkonsultasi mengenai layanan energi Anda.") @map("whatsapp_message")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ── SMTP Gateway Settings ──────────────────────────────────────────────────────

model SmtpSettings {
  id             String   @id @default("smtp_global")
  smtpHost       String   @map("smtp_host")
  smtpPort       Int      @default(587) @map("smtp_port")
  smtpEncryption String   @default("TLS") @map("smtp_encryption") // "None" | "SSL" | "TLS"
  smtpUser       String   @map("smtp_user")
  smtpPassEnc    String   @db.Text @map("smtp_pass_enc")          // AES-256 encrypted
  fromName       String   @default("PT VEA Notification") @map("from_name")
  fromEmail      String   @map("from_email")
  bccEmail       String?  @map("bcc_email")
  ignoreTls      Boolean  @default(false) @map("ignore_tls")
  lastTestStatus String?  @map("last_test_status")                // "success" | "error"
  lastTestMsg    String?  @db.Text @map("last_test_msg")
  lastTestedAt   DateTime? @map("last_tested_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("settings_smtp")
}

// ── Audit Log for SMTP changes ─────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  action     String                                                // e.g. "SMTP_UPDATE", "SMTP_TEST"
  actorId    String?  @map("actor_id")
  actorEmail String?  @map("actor_email")
  ipAddress  String?  @map("ip_address")
  details    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ── Landing Page Content Models ────────────────────────────────────────────────

model Mitra {
  id         String   @id @default(uuid())
  name       String
  logoUrl    String   @map("logo_url")      // Path file di VPS (/public/uploads/mitra/)
  websiteUrl String?  @map("website_url")
  order      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("mitra")
}

model Brand {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String   @map("logo_url")
  description String?  @db.Text
  category    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("brands")
}

// ── Payment / Orders (Midtrans Integration) ────────────────────────────────────

model Order {
  id                  String    @id @default(cuid())
  /// Harus unik & tidak bisa diubah — dipakai sebagai order_id di Midtrans
  orderId             String    @unique @map("order_id")
  grossAmount         Int       @map("gross_amount")         // Dalam satuan Rupiah (integer)
  currency            String    @default("IDR")
  status              String    @default("pending")          // pending | settlement | expire | cancel | deny | failure
  snapToken           String?   @map("snap_token")
  snapRedirectUrl     String?   @map("snap_redirect_url")
  paymentType         String?   @map("payment_type")         // Dari callback Midtrans
  transactionId       String?   @map("transaction_id")       // Midtrans transaction_id
  transactionTime     DateTime? @map("transaction_time")
  fraudStatus         String?   @map("fraud_status")         // accept | deny | challenge
  /// Timestamp untuk idempotency guard — jika sudah terisi, tolak update apapun
  paidAt              DateTime? @map("paid_at")
  /// Email pembeli (opsional, untuk notifikasi)
  customerEmail       String?   @map("customer_email")
  customerName        String?   @map("customer_name")
  /// JSON stringified item_details
  itemDetails         String?   @db.Text @map("item_details")
  /// JSON raw payload terakhir dari Midtrans webhook (untuk debugging / audit)
  lastWebhookPayload  String?   @db.Text @map("last_webhook_payload")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([customerEmail])
  @@map("orders")
}

// ── Dynamic Email Routes ───────────────────────────────────────────────────────

model EmailRoute {
  id              String   @id @default(cuid())
  name            String   @map("name")
  triggerEvent    String   @default("INQUIRY") @map("trigger_event") // "INQUIRY" | "TRANSACTION" | "CUSTOM"
  subjectTemplate String   @map("subject_template")
  toEmail         String?  @map("to_email")
  bccEmail        String?  @map("bcc_email")
  htmlTemplate    String?  @db.Text @map("html_template")
  attachProduct   Boolean  @default(false) @map("attach_product")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("email_routes")
}
