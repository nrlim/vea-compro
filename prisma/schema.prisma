// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  company   String
  email     String
  message   String
  product   String?
  createdAt DateTime @default(now())

  @@map("contact_requests")
}

// ── Admin Panel Models ─────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String
  price       String?  // Made optional for flexibility
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // Hashed password
  fullName  String?  @map("full_name")
  role      String   @default("staff") // "admin" | "staff"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model AppSettings {
  id                 String   @id @default("global")
  emailFrom          String   @default("PT VEA <noreply@ptvea.com>") @map("email_from")
  emailTo            String   @default("sales@ptvea.com") @map("email_to")
  emailBcc           String?  @map("email_bcc")
  emailSubject       String   @default("Inquiry Konsultasi Baru: {{name}} - {{company}}") @map("email_subject")
  emailHtml          String?  @db.Text @map("email_html")
  emailAttachProduct Boolean  @default(true) @map("email_attach_product")
  whatsappNumber     String?  @default("628123456789") @map("whatsapp_number")
  whatsappMessage    String?  @default("Halo PT VEA, saya ingin berkonsultasi mengenai layanan energi Anda.") @map("whatsapp_message")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

